pragma solidity ^0.8.19;

import "@openzeppelin/contracts/access/Ownable.sol";
import "./broken/interfaces/ICompliance.sol";

/**
 * @title BasicCompliance
 * @dev Basic compliance implementation for ERC-3643 tokens
 * @notice Provides investor eligibility and transfer restriction checks
 * @author BountyClaw
 */
contract BasicCompliance is ICompliance, Ownable {
    
    /// @notice Whitelist of addresses that can participate
    mapping(address => bool) public whitelistedAddresses;
    
    /// @notice Mapping of token bindings
    mapping(address => bool) public boundTokens;
    
    /// @notice Array of bound tokens
    address[] public tokenList;
    
    /// @notice Transfer limits per address
    mapping(address => uint256) public maxTransferAmount;
    
    /// @notice Global maximum transfer amount
    uint256 public globalMaxTransferAmount;
    
    /// @notice Compliance rules
    mapping(bytes32 => bytes) public rules;
    bytes32[] public ruleIds;
    
    /// @notice Events
    event AddressWhitelisted(address indexed wallet);
    event AddressRemovedFromWhitelist(address indexed wallet);
    event MaxTransferAmountSet(address indexed wallet, uint256 amount);
    event GlobalMaxTransferAmountSet(uint256 amount);
    
    /// @notice Constructor
    constructor(address initialOwner) Ownable() {
        globalMaxTransferAmount = type(uint256).max; // No limit by default
    }
    
    /**
     * @notice Add address to whitelist
     * @param _wallet Address to whitelist
     */
    function addToWhitelist(address _wallet) external onlyOwner {
        require(_wallet != address(0), "Invalid address");
        whitelistedAddresses[_wallet] = true;
        emit AddressWhitelisted(_wallet);
    }
    
    /**
     * @notice Remove address from whitelist
     * @param _wallet Address to remove
     */
    function removeFromWhitelist(address _wallet) external onlyOwner {
        whitelistedAddresses[_wallet] = false;
        emit AddressRemovedFromWhitelist(_wallet);
    }
    
    /**
     * @notice Batch add to whitelist
     * @param _wallets Array of addresses
     */
    function batchAddToWhitelist(address[] calldata _wallets) external onlyOwner {
        for (uint256 i = 0; i < _wallets.length; i++) {
            whitelistedAddresses[_wallets[i]] = true;
            emit AddressWhitelisted(_wallets[i]);
        }
    }
    
    /**
     * @notice Set max transfer amount for specific address
     * @param _wallet Address
     * @param _amount Max amount
     */
    function setMaxTransferAmount(address _wallet, uint256 _amount) external onlyOwner {
        maxTransferAmount[_wallet] = _amount;
        emit MaxTransferAmountSet(_wallet, _amount);
    }
    
    /**
     * @notice Set global max transfer amount
     * @param _amount Max amount
     */
    function setGlobalMaxTransferAmount(uint256 _amount) external onlyOwner {
        globalMaxTransferAmount = _amount;
        emit GlobalMaxTransferAmountSet(_amount);
    }
    
    /**
     * @notice Check if transfer is compliant
     * @param _from Sender
     * @param _to Receiver
     * @param _amount Amount
     */
    function canTransfer(
        address _from,
        address _to,
        uint256 _amount
    ) external view override returns (bool valid) {
        // Check whitelist
        if (!whitelistedAddresses[_from] || !whitelistedAddresses[_to]) {
            return false;
        }
        
        // Check transfer limits
        uint256 maxAmount = maxTransferAmount[_from];
        if (maxAmount == 0) {
            maxAmount = globalMaxTransferAmount;
        }
        
        if (_amount > maxAmount) {
            return false;
        }
        
        // Check custom rules
        for (uint256 i = 0; i < ruleIds.length; i++) {
            if (!_checkRule(ruleIds[i], _from, _to, _amount)) {
                return false;
            }
        }
        
        return true;
    }
    
    /**
     * @notice Check transfer from
     */
    function canTransferFrom(
        address _from,
        uint256 _amount
    ) external view override returns (bool valid) {
        if (!whitelistedAddresses[_from]) {
            return false;
        }
        
        uint256 maxAmount = maxTransferAmount[_from];
        if (maxAmount == 0) {
            maxAmount = globalMaxTransferAmount;
        }
        
        return _amount <= maxAmount;
    }
    
    /**
     * @notice Check transfer to
     */
    function canTransferTo(
        address _to,
        uint256 _amount
    ) external view override returns (bool valid) {
        if (!whitelistedAddresses[_to]) {
            return false;
        }
        
        return _amount <= globalMaxTransferAmount;
    }
    
    /**
     * @notice Internal function to check a rule
     */
    function _checkRule(
        bytes32 _ruleId,
        address _from,
        address _to,
        uint256 _amount
    ) internal view returns (bool) {
        // Basic implementation - can be extended
        // Rule format could be: minAmount, maxAmount, allowedCountries, etc.
        return true;
    }
    
    /**
     * @notice Create a compliance rule
     */
    function createRule(bytes32 _ruleId, bytes calldata _ruleData) external override onlyOwner {
        require(_ruleId != bytes32(0), "Invalid rule ID");
        require(rules[_ruleId].length == 0, "Rule already exists");
        
        rules[_ruleId] = _ruleData;
        ruleIds.push(_ruleId);
    }
    
    /**
     * @notice Remove a compliance rule
     */
    function removeRule(bytes32 _ruleId) external override onlyOwner {
        require(rules[_ruleId].length > 0, "Rule not found");
        
        delete rules[_ruleId];
        
        // Remove from array
        for (uint256 i = 0; i < ruleIds.length; i++) {
            if (ruleIds[i] == _ruleId) {
                ruleIds[i] = ruleIds[ruleIds.length - 1];
                ruleIds.pop();
                break;
            }
        }
    }
    
    /**
     * @notice Check if rule exists
     */
    function hasRule(bytes32 _ruleId) external view override returns (bool) {
        return rules[_ruleId].length > 0;
    }
    
    /**
     * @notice Bind a token to this compliance
     */
    function bindToken(address _token) external override onlyOwner {
        require(_token != address(0), "Invalid token");
        require(!boundTokens[_token], "Token already bound");
        
        boundTokens[_token] = true;
        tokenList.push(_token);
    }
    
    /**
     * @notice Unbind a token
     */
    function unbindToken(address _token) external override onlyOwner {
        require(boundTokens[_token], "Token not bound");
        
        boundTokens[_token] = false;
        
        // Remove from array
        for (uint256 i = 0; i < tokenList.length; i++) {
            if (tokenList[i] == _token) {
                tokenList[i] = tokenList[tokenList.length - 1];
                tokenList.pop();
                break;
            }
        }
    }
    
    /**
     * @notice Check if token is bound
     */
    function isTokenBound(address _token) external view override returns (bool) {
        return boundTokens[_token];
    }
    
    /**
     * @notice Get all bound tokens
     */
    function getBoundTokens() external view returns (address[] memory) {
        return tokenList;
    }
    
    /**
     * @notice Get rule count
     */
    function getRuleCount() external view returns (uint256) {
        return ruleIds.length;
    }
}
